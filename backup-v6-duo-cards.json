{"filename": "kc-page-content.html", "file_content": "<!-- wp:html -->\n<div class=\"kc-home\" style=\"font-family:'Cormorant Garamond',Georgia,serif;color:#402417;width:100%;max-width:100%;margin:0;padding:0;box-sizing:border-box\"><section class=\"kc-hero-zone\" style=\"position:relative;height:100vh\"><div class=\"kc-hero-pin\" id=\"kc-hero-pin\" style=\"position:sticky;top:0;height:100vh;overflow:hidden;background:url(https://kevincho.com/wp-content/uploads/2025/07/WhatsApp-Image-2025-06-29-at-7.10.01-PM-1.jpeg) center center/cover no-repeat\"><div class=\"kc-hero-overlay\" style=\"position:absolute;bottom:0;left:0;right:0;text-align:center;padding:80px 20px 60px;background:linear-gradient(to top,rgba(0,0,0,0.6) 0%,rgba(0,0,0,0.15) 60%,transparent 100%);z-index:5\"><h1 style=\"font-size:clamp(28px,5vw,52px);font-weight:300;color:#fff;margin:0 0 10px 0;font-family:'Cormorant Garamond',Georgia,serif;letter-spacing:2px\">Where Tradition Meets Elegance</h1><p style=\"font-size:14px;color:rgba(255,255,255,0.8);max-width:480px;margin:0 auto 28px;font-family:'Open Sans',sans-serif;font-weight:300;line-height:1.7;letter-spacing:0.5px\">Premium bespoke tailoring crafted with African heritage and modern sophistication</p><a href=\"/shop-ready-made/\" class=\"kc-btn kc-btn-hero\" style=\"display:inline-block;padding:14px 48px;font-size:11px;letter-spacing:4px;text-transform:uppercase;text-decoration:none;font-family:'Open Sans',sans-serif;background:#fff;color:#402417;border:none\">SHOP NOW</a></div></div></section><section class=\"kc-duo-section\" style=\"display:grid;grid-template-columns:1fr 1fr;gap:4px;padding:20px 0 0 0\"><div class=\"kc-duo-card\" style=\"position:relative;height:65vh;overflow:hidden;background:url(https://kevincho.com/wp-content/uploads/2025/06/efegrgf.gif) center center/cover no-repeat\"><a href=\"/product-category/men/suits/\" class=\"kc-duo-link\" style=\"position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding:40px 20px;text-decoration:none;z-index:2\"><h3 style=\"color:#fff;font-size:clamp(22px,3vw,34px);font-weight:300;margin:0 0 16px 0;font-family:'Cormorant Garamond',Georgia,serif;letter-spacing:3px\">Suits</h3><span class=\"kc-duo-btn\" style=\"display:inline-block;padding:12px 36px;font-size:11px;letter-spacing:3px;text-transform:uppercase;font-family:'Open Sans',sans-serif;border:1px solid #fff;color:#fff;background:transparent\">SHOP NOW</span></a></div><div class=\"kc-duo-card\" style=\"position:relative;height:65vh;overflow:hidden;background:url(https://kevincho.com/wp-content/uploads/2025/06/gntyj.jpg) center center/cover no-repeat\"><a href=\"/product-category/men/agbada/\" class=\"kc-duo-link\" style=\"position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding:40px 20px;text-decoration:none;z-index:2\"><h3 style=\"color:#fff;font-size:clamp(22px,3vw,34px);font-weight:300;margin:0 0 16px 0;font-family:'Cormorant Garamond',Georgia,serif;letter-spacing:3px\">Agbada</h3><span class=\"kc-duo-btn\" style=\"display:inline-block;padding:12px 36px;font-size:11px;letter-spacing:3px;text-transform:uppercase;font-family:'Open Sans',sans-serif;border:1px solid #fff;color:#fff;background:transparent\">SHOP NOW</span></a></div></section><section class=\"kc-duo-section\" style=\"display:grid;grid-template-columns:1fr 1fr;gap:4px;padding:0\"><div class=\"kc-duo-card\" style=\"position:relative;height:65vh;overflow:hidden;background:url(https://kevincho.com/wp-content/uploads/2025/06/fqefqefqef.gif) center center/cover no-repeat\"><a href=\"/product-category/men/kaftan/\" class=\"kc-duo-link\" style=\"position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding:40px 20px;text-decoration:none;z-index:2\"><h3 style=\"color:#fff;font-size:clamp(22px,3vw,34px);font-weight:300;margin:0 0 16px 0;font-family:'Cormorant Garamond',Georgia,serif;letter-spacing:3px\">Kaftan</h3><span class=\"kc-duo-btn\" style=\"display:inline-block;padding:12px 36px;font-size:11px;letter-spacing:3px;text-transform:uppercase;font-family:'Open Sans',sans-serif;border:1px solid #fff;color:#fff;background:transparent\">SHOP NOW</span></a></div><div class=\"kc-duo-card\" style=\"position:relative;height:65vh;overflow:hidden;background:url(https://kevincho.com/wp-content/uploads/2025/06/etyu76u.jpg) center center/cover no-repeat\"><a href=\"/product-category/men/dashiki/\" class=\"kc-duo-link\" style=\"position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding:40px 20px;text-decoration:none;z-index:2\"><h3 style=\"color:#fff;font-size:clamp(22px,3vw,34px);font-weight:300;margin:0 0 16px 0;font-family:'Cormorant Garamond',Georgia,serif;letter-spacing:3px\">Dashiki</h3><span class=\"kc-duo-btn\" style=\"display:inline-block;padding:12px 36px;font-size:11px;letter-spacing:3px;text-transform:uppercase;font-family:'Open Sans',sans-serif;border:1px solid #fff;color:#fff;background:transparent\">SHOP NOW</span></a></div></section><section class=\"kc-custom-banner kc-content-fade\" style=\"position:relative;height:400px;overflow:hidden;background:#402417\"><div style=\"position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:40px 20px;z-index:2\"><div style=\"font-size:12px;letter-spacing:6px;text-transform:uppercase;color:#c9a96e;margin:0 0 16px 0;font-family:'Open Sans',sans-serif\">Bespoke Tailoring</div><h2 style=\"font-size:clamp(28px,4.5vw,44px);font-weight:300;color:#fff;margin:0 0 16px 0;font-family:'Cormorant Garamond',Georgia,serif;letter-spacing:2px\">Made to Measure</h2><p style=\"font-size:15px;color:rgba(255,255,255,0.65);max-width:460px;margin:0 auto 32px;font-family:'Open Sans',sans-serif;font-weight:300;line-height:1.7\">Every garment crafted exclusively for you, from fabric selection to final stitch</p><a href=\"/product/custom-wear/\" class=\"kc-btn kc-btn-gold\" style=\"display:inline-block;padding:14px 48px;font-size:11px;letter-spacing:4px;text-transform:uppercase;text-decoration:none;font-family:'Open Sans',sans-serif;background:#c9a96e;color:#402417;border:2px solid #c9a96e\">CUSTOM WEAR</a></div></section><section class=\"kc-brand-strip\" style=\"padding:50px 20px;background:#faf7f3;text-align:center\"><p style=\"font-size:clamp(16px,2.5vw,22px);font-weight:300;color:#402417;font-family:'Cormorant Garamond',Georgia,serif;font-style:italic;letter-spacing:1px;margin:0;line-height:1.6\">Crafted in Cameroon &mdash; Worn Worldwide</p></section><section class=\"kc-features kc-content-fade\" style=\"padding:80px 20px;background:#fff;text-align:center\"><div class=\"kc-section-tag\" style=\"font-size:12px;letter-spacing:6px;text-transform:uppercase;color:#c9a96e;margin:0 0 16px 0;font-family:'Open Sans',sans-serif\">Why Kevin Cho</div><h2 class=\"kc-section-h2\" style=\"font-size:clamp(30px,5vw,48px);font-weight:300;color:#402417;margin:0 0 60px 0;line-height:1.2;font-family:'Cormorant Garamond',Georgia,serif\">The Art of Bespoke</h2><div class=\"kc-feat-grid\" style=\"display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:60px;max-width:960px;margin:0 auto\"><div class=\"kc-feat-item\" style=\"padding:20px\"><svg class=\"kc-feat-icon\" viewBox=\"0 0 24 24\" style=\"width:48px;height:48px;display:block;margin:0 auto 20px;stroke:#c9a96e;fill:none;stroke-width:1.2\"><path d=\"M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z\"/></svg><h3 style=\"font-size:24px;font-weight:400;margin:0 0 12px 0;color:#402417;font-family:'Cormorant Garamond',Georgia,serif\">Handcrafted</h3><p style=\"font-size:15px;line-height:1.8;color:#6b5a4e;font-family:'Open Sans',sans-serif;font-weight:300;margin:0\">Every garment is meticulously crafted by hand with attention to the finest details.</p></div><div class=\"kc-feat-item\" style=\"padding:20px\"><svg class=\"kc-feat-icon\" viewBox=\"0 0 24 24\" style=\"width:48px;height:48px;display:block;margin:0 auto 20px;stroke:#c9a96e;fill:none;stroke-width:1.2\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg><h3 style=\"font-size:24px;font-weight:400;margin:0 0 12px 0;color:#402417;font-family:'Cormorant Garamond',Georgia,serif\">Premium Fabrics</h3><p style=\"font-size:15px;line-height:1.8;color:#6b5a4e;font-family:'Open Sans',sans-serif;font-weight:300;margin:0\">We source only the finest fabrics from across Africa and around the world.</p></div><div class=\"kc-feat-item\" style=\"padding:20px\"><svg class=\"kc-feat-icon\" viewBox=\"0 0 24 24\" style=\"width:48px;height:48px;display:block;margin:0 auto 20px;stroke:#c9a96e;fill:none;stroke-width:1.2\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z\"/></svg><h3 style=\"font-size:24px;font-weight:400;margin:0 0 12px 0;color:#402417;font-family:'Cormorant Garamond',Georgia,serif\">Worldwide Delivery</h3><p style=\"font-size:15px;line-height:1.8;color:#6b5a4e;font-family:'Open Sans',sans-serif;font-weight:300;margin:0\">From Cameroon to the world \u2014 we deliver our craftsmanship to your doorstep.</p></div></div></section><section class=\"kc-cta kc-content-fade\" style=\"padding:100px 20px;background:#402417;text-align:center\"><h2 style=\"font-size:clamp(28px,5vw,46px);color:#fff;font-weight:300;margin:0 0 16px 0;font-family:'Cormorant Garamond',Georgia,serif\">Your Perfect Fit Awaits</h2><p style=\"color:rgba(255,255,255,0.65);font-size:16px;max-width:480px;margin:0 auto 44px;font-family:'Open Sans',sans-serif;font-weight:300;line-height:1.8\">Book a consultation and let us create something extraordinary, tailored exclusively for you.</p><div class=\"kc-btn-row\" style=\"display:flex;gap:20px;justify-content:center;flex-wrap:wrap\"><a href=\"/consultation/\" class=\"kc-btn kc-btn-gold\" style=\"display:inline-block;padding:16px 44px;font-size:12px;letter-spacing:3px;text-transform:uppercase;text-decoration:none;font-family:'Open Sans',sans-serif;background:#c9a96e;color:#402417;border:2px solid #c9a96e\">Book a Consultation</a> <a href=\"/product/custom-wear/\" class=\"kc-btn kc-btn-outline\" style=\"display:inline-block;padding:16px 44px;font-size:12px;letter-spacing:3px;text-transform:uppercase;text-decoration:none;font-family:'Open Sans',sans-serif;background:transparent;color:#fff;border:2px solid rgba(255,255,255,0.4)\">Custom Wear</a></div></section></div>\n<!-- /wp:html -->"}
